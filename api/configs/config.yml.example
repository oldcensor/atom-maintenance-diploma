server:
  host: "0.0.0.0"
  port: 8080
  cors_allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:5173"

postgres:
  url: "postgres://user:pass@localhost:5432/atom_maintenance?sslmode=disable"
  pool_size: 10
  min_idle_conns: 2
  dial_timeout: "5s"

redis:
  url: "redis://:pass@localhost:6379/0"
  pool_size: 10
  min_idle_conns: 2
  dial_timeout: "3s"

timeouts:
  http_request: "10s"
  db_query: "5s"
  cache_op: "2s"

jwt:
  secret: "replace-with-random-32-char-string"
  access_ttl: "15m"
  refresh_ttl: "720h"

logger:
  level: "debug"
  service: "atom-maintenance-api"
  env: "local"
  version: "0.1.0"
